{
  "version": "1.0.0",
  "description": "Unity 게임 개발 스킬 자동 활성화 설정",
  "skills": {
    "game-planning-v2": {
      "type": "domain",
      "enforcement": "suggest",
      "priority": "high",
      "description": "V2 기획 에이전트 팀 기반 종합 기획 워크플로우",
      "promptTriggers": {
        "keywords": [
          "기획 v2", "plan", "시장 분석", "밸런스 설계",
          "경제 설계", "콘텐츠 설계", "ux 플로우", "기술 평가",
          "design critic", "에이전트 평가", "문서 리뷰"
        ],
        "intentPatterns": [
          "(plan|기획).*(init|market|vision|system|balance|economy|ux|content|assess|wbs|status|review|eval)"
        ]
      },
      "fileTriggers": {
        "pathPatterns": [
          "Docs/V2/**/*.md"
        ]
      }
    },
    "skill-developer": {
      "type": "domain",
      "enforcement": "suggest",
      "priority": "high",
      "description": "Claude Code 스킬 생성 및 관리 메타-스킬. skill-rules.json 수정, 트리거 패턴 설계, 훅 시스템, 500-line 규칙, 점진적 공개 패턴",
      "promptTriggers": {
        "keywords": [
          "skill system",
          "스킬 만들기",
          "스킬 추가",
          "skill triggers",
          "skill-rules.json",
          "hook system",
          "skill development",
          "훅 설정",
          "스킬 시스템"
        ],
        "intentPatterns": [
          "(how do|how does|explain).*?skill",
          "(create|add|modify|build).*?skill",
          "skill.*?(work|trigger|activate|system)",
          "(만들어|추가|수정).*?스킬",
          "스킬.*?(동작|트리거|활성화)"
        ]
      },
      "fileTriggers": {
        "pathPatterns": [
          ".claude/skills/**/*.md",
          ".claude/skills/skill-rules.json",
          ".claude/hooks/**/*.ts",
          ".claude/hooks/**/*.sh"
        ]
      }
    }
  },
  "notes": {
    "enforcement_types": {
      "suggest": "스킬 제안만 표시, 실행 차단 없음",
      "block": "스킬 사용 전까지 Edit/Write 차단 (가드레일)",
      "warn": "경고 표시, 진행은 허용"
    },
    "priority_levels": {
      "critical": "항상 트리거",
      "high": "명확한 매칭 시 트리거",
      "medium": "일반적 매칭",
      "low": "명시적 매칭만"
    }
  }
}
