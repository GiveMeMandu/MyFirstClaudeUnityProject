{
  "permissions": {
    "allow": [
      "Bash(npx tsx:*)",
      "Bash(chmod:*)",
      "Bash(git clone:*)",
      "Bash(rm -rf /tmp/*)",
      "Bash(claude plugin:*)",
      "Skill(discord:configure)",
      "Read(//c/Users/wooch/.claude/channels/discord/**)",
      "Bash(bash \"$CLAUDE_PROJECT_DIR/.claude/scripts/task-start.sh\":*)",
      "Bash(bash \"$CLAUDE_PROJECT_DIR/.claude/scripts/task-commit.sh\":*)",
      "Bash(bash \"$CLAUDE_PROJECT_DIR/.claude/scripts/task-commit-sf.sh\":*)",
      "Bash(bash \"$CLAUDE_PROJECT_DIR/.claude/scripts/task-pr.sh\":*)",
      "Bash(bash \"$CLAUDE_PROJECT_DIR/.claude/scripts/task-cleanup.sh\":*)",
      "Bash(bash \"$CLAUDE_PROJECT_DIR/.claude/scripts/ps-counter-init.sh\":*)",
      "Bash(bash \"$CLAUDE_PROJECT_DIR/.claude/scripts/worktree-create.sh\":*)",
      "Bash(bash \"$CLAUDE_PROJECT_DIR/.claude/scripts/worktree-init-all.sh\":*)",
      "Bash(bash \"$CLAUDE_PROJECT_DIR/.claude/scripts/worktree-compile-verify.sh\":*)",
      "Bash(bash \"$CLAUDE_PROJECT_DIR/.claude/scripts/worktree-cleanup.sh\":*)",
      "Bash(git checkout:*)",
      "Bash(git pull:*)",
      "Bash(git push:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git branch:*)",
      "Bash(git worktree:*)",
      "Bash(\"/c/Program Files/GitHub CLI/gh.exe\" pr:*)",
      "Bash(/c/Users/wooch/AppData/Local/unity-cli.exe:*)"
    ]
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/skill-activation-prompt.sh"
          },
          {
            "type": "command",
            "command": "bash $CLAUDE_PROJECT_DIR/.claude/hooks/session-start-tracker.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|MultiEdit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/post-tool-use-tracker.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash $CLAUDE_PROJECT_DIR/.claude/hooks/unity-compile-check.sh",
            "timeout": 30,
            "statusMessage": "Unity 컴파일 에러 체크 중..."
          },
          {
            "type": "command",
            "command": "bash $CLAUDE_PROJECT_DIR/.claude/hooks/session-log.sh",
            "timeout": 15,
            "statusMessage": "세션 로그 기록 중..."
          }
        ]
      }
    ]
  }
}
