<UXML xmlns="UnityEngine.UIElements">
    <Style src="../../USS/Theme/Variables.uss" />
    <Style src="../../USS/Components/ResourceBar.uss" />

    <VisualElement name="resource-hud" class="resource-hud">
        <VisualElement class="resource-group">
            <!-- Basic Resource -->
            <VisualElement name="resource-basic" class="resource-item">
                <VisualElement class="resource-icon resource-icon--basic" />
                <Label class="resource-name" text="Basic" />
                <Label name="basic-value" class="resource-label" text="0" />
            </VisualElement>

            <!-- Advanced Resource -->
            <VisualElement name="resource-advanced" class="resource-item">
                <VisualElement class="resource-icon resource-icon--advanced" />
                <Label class="resource-name" text="Advanced" />
                <Label name="advanced-value" class="resource-label" text="0" />
            </VisualElement>

            <!-- Relic Resource -->
            <VisualElement name="resource-relic" class="resource-item">
                <VisualElement class="resource-icon resource-icon--relic" />
                <Label class="resource-name" text="Relic" />
                <Label name="relic-value" class="resource-label" text="0" />
            </VisualElement>
        </VisualElement>

        <!-- Turn Display -->
        <VisualElement name="turn-display" class="turn-display">
            <Label class="turn-label" text="TURN" />
            <Label name="turn-number" class="turn-number" text="1" />
        </VisualElement>
    </VisualElement>
</UXML>
