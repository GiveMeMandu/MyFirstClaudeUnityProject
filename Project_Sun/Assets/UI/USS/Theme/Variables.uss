/* === Project Sun — UI Toolkit PoC Theme Variables === */

:root {
    /* Colors */
    --color-bg-dark: rgb(20, 18, 24);
    --color-bg-panel: rgb(30, 28, 36);
    --color-bg-card: rgb(42, 38, 50);
    --color-bg-hover: rgb(55, 50, 65);
    --color-bg-selected: rgb(70, 60, 90);

    --color-border: rgb(80, 70, 100);
    --color-border-highlight: rgb(140, 120, 200);

    --color-text-primary: rgb(230, 225, 240);
    --color-text-secondary: rgb(160, 150, 180);
    --color-text-dim: rgb(100, 95, 115);

    --color-accent: rgb(120, 90, 220);
    --color-accent-hover: rgb(140, 110, 240);

    --color-resource-basic: rgb(180, 140, 80);
    --color-resource-advanced: rgb(80, 160, 200);
    --color-resource-relic: rgb(200, 120, 220);

    --color-sufficient: rgb(120, 200, 120);
    --color-insufficient: rgb(220, 80, 80);

    --color-socket-valid: rgb(80, 200, 120);
    --color-socket-invalid: rgb(200, 80, 80);

    --color-turn: rgb(240, 200, 80);

    /* Sizes */
    --spacing-xs: 4px;
    --spacing-sm: 8px;
    --spacing-md: 12px;
    --spacing-lg: 16px;
    --spacing-xl: 24px;

    --radius-sm: 4px;
    --radius-md: 8px;
    --radius-lg: 12px;

    --font-size-sm: 12px;
    --font-size-md: 14px;
    --font-size-lg: 18px;
    --font-size-xl: 24px;
    --font-size-xxl: 32px;
}
