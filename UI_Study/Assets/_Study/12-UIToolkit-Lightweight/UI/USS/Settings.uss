.root {
    flex-grow: 1;
    background-color: rgb(25, 25, 35);
    padding: 20px;
    align-items: center;
    justify-content: center;
}

.title-bar {
    flex-direction: row;
    justify-content: space-between;
    align-items: center;
    width: 500px;
    margin-bottom: 8px;
}

.title {
    font-size: 18px;
    color: rgb(180, 180, 200);
    -unity-font-style: bold;
}

.btn-close {
    width: 28px;
    height: 28px;
    background-color: rgb(70, 70, 90);
    color: rgb(200, 200, 220);
    border-width: 0;
    border-radius: 14px;
    font-size: 14px;
    -unity-font-style: bold;
    -unity-text-align: middle-center;
    transition-property: background-color;
    transition-duration: 0.15s;
}
.btn-close:hover { background-color: rgb(220, 60, 60); color: white; }

.settings-container {
    width: 500px;
    background-color: rgb(30, 30, 42);
    border-radius: 10px;
    border-width: 1px;
    border-color: rgb(50, 50, 70);
    padding: 16px;
}

/* TabView styling */
.settings-tabs {
    flex-grow: 1;
}

.unity-tab__header {
    background-color: rgb(35, 35, 50);
    border-radius: 6px 6px 0 0;
    padding: 4px 16px;
    margin-right: 2px;
    color: rgb(140, 140, 170);
    font-size: 13px;
    -unity-font-style: bold;

    transition-property: background-color, color;
    transition-duration: 0.2s;
}

.unity-tab__header:hover {
    background-color: rgb(45, 45, 65);
    color: rgb(200, 200, 220);
}

.unity-tab__header--active {
    background-color: rgb(50, 60, 90);
    color: rgb(255, 255, 255);
}

/* Tab content area */
.tab-content {
    padding: 20px 12px;
    min-height: 120px;
}

.setting-field {
    margin-bottom: 16px;
}

/* Label styling for fields */
.setting-field > Label {
    color: rgb(180, 180, 200);
    font-size: 13px;
    min-width: 120px;
}

/* Dropdown styling */
.setting-field > .unity-popup-field__input {
    background-color: rgb(40, 40, 55);
    border-color: rgb(60, 60, 80);
    border-radius: 4px;
    color: rgb(220, 220, 240);
}

/* Slider styling */
.setting-field .unity-base-slider__dragger {
    background-color: rgb(100, 140, 255);
    border-radius: 50%;
    width: 16px;
    height: 16px;
    margin-top: -6px;
}

.setting-field .unity-base-slider__tracker {
    background-color: rgb(50, 50, 70);
    border-radius: 3px;
    height: 4px;
}

/* Toggle styling */
.setting-field .unity-toggle__checkmark {
    background-color: rgb(40, 40, 55);
    border-color: rgb(60, 60, 80);
    border-radius: 4px;
}

.setting-field .unity-toggle__input:checked .unity-toggle__checkmark {
    background-color: rgb(100, 140, 255);
}

/* Button bar */
.button-bar {
    flex-direction: row;
    justify-content: flex-end;
    margin-top: 16px;
    padding-top: 12px;
    border-top-width: 1px;
    border-top-color: rgb(50, 50, 70);
}

.btn {
    height: 34px;
    padding-left: 24px;
    padding-right: 24px;
    margin-left: 8px;
    border-radius: 6px;
    font-size: 13px;
    -unity-font-style: bold;
    border-width: 0;

    transition-property: background-color, scale;
    transition-duration: 0.15s;
}

.btn:active { scale: 0.95; }

.btn-apply {
    background-color: rgb(56, 142, 60);
    color: white;
}
.btn-apply:hover { background-color: rgb(76, 175, 80); }

.btn-cancel {
    background-color: rgb(80, 80, 100);
    color: rgb(200, 200, 220);
}
.btn-cancel:hover { background-color: rgb(100, 100, 120); }
