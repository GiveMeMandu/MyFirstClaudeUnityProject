/* === Root Container === */
.root {
    flex-grow: 1;
    align-items: center;
    justify-content: center;
    background-color: rgb(30, 30, 40);
    padding: 40px;
}

/* === Card === */
.card {
    flex-direction: row;
    background-color: rgb(45, 45, 60);
    border-radius: 12px;
    padding: 20px;
    border-width: 2px;
    border-color: rgb(70, 70, 90);
    width: 420px;

    /* CSS Transition: hover 시 배경색+border 변경 */
    transition-property: background-color, border-color, scale;
    transition-duration: 0.2s, 0.2s, 0.15s;
    transition-timing-function: ease-out;
}

.card:hover {
    background-color: rgb(55, 55, 75);
    border-color: rgb(100, 140, 255);
    scale: 1.02;
}

/* === Avatar === */
.avatar {
    width: 80px;
    height: 80px;
    border-radius: 40px;
    background-color: rgb(100, 140, 255);
    align-items: center;
    justify-content: center;
    margin-right: 16px;
    flex-shrink: 0;
}

.avatar-initial {
    font-size: 32px;
    color: rgb(255, 255, 255);
    -unity-text-align: middle-center;
    -unity-font-style: bold;
}

/* === Info === */
.info {
    flex-grow: 1;
    justify-content: center;
}

.player-name {
    font-size: 22px;
    color: rgb(240, 240, 255);
    -unity-font-style: bold;
    margin-bottom: 4px;
}

.player-level {
    font-size: 14px;
    color: rgb(160, 160, 190);
    margin-bottom: 10px;
}

/* === Stats Row === */
.stats-row {
    flex-direction: row;
}

.stat {
    margin-right: 16px;
    align-items: center;
}

.stat-label {
    font-size: 10px;
    color: rgb(120, 120, 150);
    -unity-text-align: upper-center;
}

.stat-value {
    font-size: 16px;
    color: rgb(200, 220, 255);
    -unity-font-style: bold;
    -unity-text-align: upper-center;
}

/* === Buttons === */
.button-row {
    flex-direction: row;
    justify-content: center;
    margin-top: 16px;
}

.btn {
    height: 36px;
    padding-left: 20px;
    padding-right: 20px;
    margin-left: 6px;
    margin-right: 6px;
    border-radius: 6px;
    font-size: 14px;
    -unity-font-style: bold;
    border-width: 0;

    transition-property: background-color, scale;
    transition-duration: 0.15s;
    transition-timing-function: ease-out;
}

.btn:active {
    scale: 0.95;
}

.btn-primary {
    background-color: rgb(80, 130, 255);
    color: rgb(255, 255, 255);
}

.btn-primary:hover {
    background-color: rgb(100, 150, 255);
}

.btn-secondary {
    background-color: rgb(70, 70, 90);
    color: rgb(200, 200, 220);
}

.btn-secondary:hover {
    background-color: rgb(90, 90, 110);
}

/* === Status Label === */
.status-label {
    font-size: 12px;
    color: rgb(100, 200, 120);
    -unity-text-align: upper-center;
    margin-top: 12px;
}
