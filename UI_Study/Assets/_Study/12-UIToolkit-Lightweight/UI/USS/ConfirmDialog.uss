.root {
    flex-grow: 1;
    align-items: center;
    justify-content: center;
    background-color: rgb(25, 25, 35);
}

.btn-trigger {
    height: 40px;
    padding-left: 30px;
    padding-right: 30px;
    background-color: rgb(80, 130, 255);
    color: white;
    font-size: 16px;
    -unity-font-style: bold;
    border-width: 0;
    border-radius: 8px;
    margin-bottom: 12px;
    transition-property: background-color, scale;
    transition-duration: 0.15s;
}
.btn-trigger:hover { background-color: rgb(100, 150, 255); }
.btn-trigger:active { scale: 0.95; }

.btn-loading {
    background-color: rgb(56, 142, 60);
}
.btn-loading:hover { background-color: rgb(76, 175, 80); }

.result-label {
    font-size: 14px;
    color: rgb(200, 200, 220);
    margin-bottom: 20px;
    min-height: 20px;
}

/* Modal overlay */
.modal-overlay {
    display: none;
    position: absolute;
    left: 0; top: 0; right: 0; bottom: 0;
    background-color: rgba(0, 0, 0, 0.6);
    align-items: center;
    justify-content: center;
}

.dialog-panel {
    background-color: rgb(50, 50, 70);
    border-radius: 12px;
    padding: 24px;
    min-width: 320px;
    border-width: 1px;
    border-color: rgb(80, 80, 110);
}

.dialog-title {
    font-size: 20px;
    color: rgb(240, 240, 255);
    -unity-font-style: bold;
    margin-bottom: 8px;
}

.dialog-message {
    font-size: 14px;
    color: rgb(180, 180, 200);
    margin-bottom: 20px;
}

.dialog-buttons {
    flex-direction: row;
    justify-content: flex-end;
}

.btn {
    height: 34px;
    padding-left: 20px;
    padding-right: 20px;
    border-radius: 6px;
    font-size: 14px;
    -unity-font-style: bold;
    border-width: 0;
    margin-left: 8px;
    transition-property: background-color;
    transition-duration: 0.15s;
}

.btn-confirm {
    background-color: rgb(80, 130, 255);
    color: white;
}
.btn-confirm:hover { background-color: rgb(100, 150, 255); }

.btn-cancel {
    background-color: rgb(70, 70, 90);
    color: rgb(200, 200, 220);
}
.btn-cancel:hover { background-color: rgb(90, 90, 110); }

/* Loading overlay */
.loading-overlay {
    display: none;
    position: absolute;
    left: 0; top: 0; right: 0; bottom: 0;
    background-color: rgba(0, 0, 0, 0.8);
    align-items: center;
    justify-content: center;
}

.loading-panel {
    align-items: center;
    min-width: 300px;
}

.loading-title {
    font-size: 18px;
    color: rgb(240, 240, 255);
    -unity-font-style: bold;
    margin-bottom: 16px;
}

.progress-bar {
    width: 280px;
    height: 20px;
}

.progress-label {
    font-size: 14px;
    color: rgb(180, 180, 200);
    margin-top: 8px;
}
