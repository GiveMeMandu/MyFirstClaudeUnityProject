/* Tooltip container — position absolute, hidden by default */
.tooltip-root {
    position: absolute;
    display: none;
    background-color: rgba(20, 20, 30, 0.95);
    border-radius: 6px;
    border-width: 1px;
    border-color: rgb(80, 80, 110);
    padding: 8px 12px;
    max-width: 200px;
}

.tooltip-name {
    font-size: 13px;
    color: rgb(240, 240, 255);
    -unity-font-style: bold;
    margin-bottom: 4px;
}

.tooltip-cost-row {
    flex-direction: row;
    align-items: center;
    margin-bottom: 4px;
}

.tooltip-cost-icon {
    width: 16px;
    height: 16px;
    border-radius: 8px;
    font-size: 9px;
    -unity-font-style: bold;
    -unity-text-align: middle-center;
    margin-right: 3px;
}

.tooltip-cost-icon--gold {
    background-color: rgb(255, 200, 50);
    color: rgb(40, 30, 0);
}

.tooltip-cost-icon--wood {
    background-color: rgb(139, 90, 43);
    color: rgb(255, 230, 200);
}

.tooltip-cost-value {
    font-size: 11px;
    color: rgb(200, 200, 220);
    margin-right: 8px;
}

.tooltip-desc {
    font-size: 11px;
    color: rgb(160, 160, 180);
    white-space: normal;
}
