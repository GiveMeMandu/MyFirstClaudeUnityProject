.root {
    flex-grow: 1;
    background-color: rgb(25, 25, 35);
}

/* Backdrop overlay */
.backdrop {
    position: absolute;
    left: 0; top: 0; right: 0; bottom: 0;
    background-color: rgba(0, 0, 0, 0.6);
    align-items: center;
    justify-content: center;
    display: none;
}

/* Card panel */
.detail-card {
    background-color: rgb(40, 40, 58);
    border-radius: 12px;
    border-width: 1px;
    border-color: rgb(70, 70, 100);
    padding: 20px;
    min-width: 340px;
    max-width: 400px;

    transition-property: scale, opacity;
    transition-duration: 0.2s;
}

/* Header row */
.card-header {
    flex-direction: row;
    align-items: center;
    margin-bottom: 12px;
}

.building-icon-container {
    width: 48px;
    height: 48px;
    border-radius: 8px;
    background-color: rgb(60, 60, 85);
    align-items: center;
    justify-content: center;
    margin-right: 12px;
    border-width: 1px;
    border-color: rgb(80, 80, 110);
}

.building-icon {
    font-size: 24px;
    color: rgb(200, 180, 100);
    -unity-font-style: bold;
    -unity-text-align: middle-center;
}

.header-info {
    flex-grow: 1;
}

.building-name {
    font-size: 18px;
    color: rgb(240, 240, 255);
    -unity-font-style: bold;
}

.building-level {
    font-size: 12px;
    color: rgb(140, 140, 170);
    margin-top: 2px;
}

/* Close button */
.btn-close {
    width: 28px;
    height: 28px;
    border-radius: 14px;
    background-color: rgb(60, 60, 80);
    color: rgb(180, 180, 200);
    font-size: 14px;
    -unity-font-style: bold;
    border-width: 0;
    -unity-text-align: middle-center;
    padding: 0;

    transition-property: background-color;
    transition-duration: 0.15s;
}
.btn-close:hover {
    background-color: rgb(198, 40, 40);
    color: white;
}

/* Description */
.building-desc {
    font-size: 13px;
    color: rgb(180, 180, 200);
    white-space: normal;
    margin-bottom: 12px;
}

/* Separator */
.separator {
    height: 1px;
    background-color: rgb(60, 60, 85);
    margin-bottom: 12px;
}

/* Section title */
.section-title {
    font-size: 12px;
    color: rgb(130, 130, 160);
    -unity-font-style: bold;
    letter-spacing: 1px;
    margin-bottom: 8px;
}

/* Cost row */
.cost-row {
    flex-direction: row;
    margin-bottom: 16px;
}

.cost-item {
    flex-direction: row;
    align-items: center;
    margin-right: 24px;
    padding: 6px 12px;
    background-color: rgb(50, 50, 70);
    border-radius: 6px;
}

.cost-icon {
    width: 24px;
    height: 24px;
    border-radius: 12px;
    font-size: 12px;
    -unity-font-style: bold;
    -unity-text-align: middle-center;
    margin-right: 8px;
}

.cost-icon--gold {
    background-color: rgb(255, 200, 50);
    color: rgb(40, 30, 0);
}

.cost-icon--wood {
    background-color: rgb(139, 90, 43);
    color: rgb(255, 230, 200);
}

.cost-value {
    font-size: 16px;
    color: rgb(240, 240, 255);
    -unity-font-style: bold;
}

/* Upgrade button */
.btn-upgrade {
    height: 40px;
    background-color: rgb(56, 142, 60);
    color: white;
    font-size: 15px;
    -unity-font-style: bold;
    border-width: 0;
    border-radius: 8px;
    margin-bottom: 8px;

    transition-property: background-color, scale;
    transition-duration: 0.15s;
}
.btn-upgrade:hover {
    background-color: rgb(76, 175, 80);
}
.btn-upgrade:active {
    scale: 0.97;
}
.btn-upgrade:disabled {
    background-color: rgb(60, 60, 80);
    color: rgb(120, 120, 140);
}

/* Status label */
.status-label {
    font-size: 12px;
    color: rgb(255, 200, 50);
    -unity-text-align: upper-center;
    min-height: 16px;
}
